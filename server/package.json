{
  "name": "marketplace-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Social Marketplace Backend with HTTP Polling",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "build": "npx tailwindcss -i ./public/styles/input.css -o ./public/styles/style.css --content ./views/**/*.ejs ./public/components/**/*.js --minify",
    "watch:css": "npx tailwindcss -i ./public/styles/input.css -o ./public/styles/style.css --content ./views/**/*.ejs ./public/components/**/*.js --watch"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "express": "^4.22.1",
    "lit": "^3.3.2",
    "mongodb": "^7.1.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "nodemon": "^3.0.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.4"
  }
}
