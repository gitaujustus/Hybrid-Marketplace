<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Listings | InterIntel Marketplace</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/styles/style.css" />
    <script type="module" src="/components/user-listings.js"></script>
    <script type="module" src="/components/item-card.js"></script>  
    <script type="module" src="/utils/auth.js"></script> 
</head>
<body class="bg-gray-50 text-slate-900 antialiased font-sans">
    <div class="min-h-screen flex flex-col">
        <header class="sticky top-0 z-50 w-full border-b border-gray-200 bg-white/80 backdrop-blur-md">
            <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
                <div class="flex h-16 items-center justify-between">
                    <div class="flex items-center gap-2">
                        <div class="h-8 w-8 rounded-lg bg-indigo-600 flex items-center justify-center">
                            <span class="text-white font-bold text-xl">I</span>
                        </div>
                        <span class="text-xl font-bold tracking-tight text-slate-900">InterIntel</span>
                    </div>
                    <nav id="navLinks" class="hidden md:flex items-center gap-8">
                        <!-- Links will be inserted here by JavaScript -->
                    </nav>
                    <div class="flex items-center gap-4" id="authSection">
                        <!-- Auth buttons will be inserted here by JavaScript -->
                    </div>
                </div>
            </div>
        </header>
        <main class="flex-grow mx-auto w-full max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
            <section class="mb-10">
                <h2 class="text-3xl font-bold text-slate-900 sm:text-4xl">My Listings</h2>
                <p class="mt-3 text-lg text-slate-600">Manage your collectible listings.</p>
            </section>
            <user-listings></user-listings>
        </main>
        <footer class="border-t border-gray-200 bg-white py-8">
            <div class="mx-auto max-w-7xl px-4 text-center text-sm text-slate-500">
                &copy; 2026 InterIntel Engineering Challenge. Built with EJS & Lit.
            </div>
        </footer>
    </div>
        <script type="module">
        import { getUser, updateAuthSection, updateNav } from '/utils/auth.js';
        const user = getUser();
        updateNav(!!user);
        updateAuthSection(!!user);
</script>
</body>
</html>